{%- assign overlay_pct = section.settings.overlay_opacity | default: 0 -%}

<section class="lm-hero full-width" aria-label="Hero">

  <div class="lm-hero__background" aria-hidden="true" style="--overlay: {{ overlay_pct }}%">
    {%- if section.settings.image_dark != blank -%}
      {%- render 'image', image: section.settings.image_dark, class: 'lm-hero__bg lm-hero__bg--dark' -%}
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0823/5728/9303/files/hero_H2_atmosphere.png?v=1778331595"
           alt="" class="lm-hero__bg lm-hero__bg--dark" loading="eager" fetchpriority="high" width="2000" height="1125">
    {%- endif -%}

    {%- if section.settings.image_light != blank -%}
      {%- render 'image', image: section.settings.image_light, class: 'lm-hero__bg lm-hero__bg--light' -%}
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0823/5728/9303/files/hero_H3_lifestyle.png?v=1778330624"
           alt="" class="lm-hero__bg lm-hero__bg--light" loading="eager" fetchpriority="high" width="2000" height="1125">
    {%- endif -%}
  </div>

  <div class="lm-hero__content-inner">
    
    <div class="lm-hero__top-row">
      <div class="lm-hero__eyebrow lm-hero__text-light">
        {{ section.settings.eyebrow_left | default: 'EXKLUSIVE BEAUTY-WELT' }}
      </div>
      <div class="lm-hero__eyebrow-right lm-hero__text-light hidden-mobile">
        {{ section.settings.eyebrow_right | default: 'PREMIUM MARKEN<br>100% ORIGINAL<br>SCHNELLER VERSAND' }}
      </div>
    </div>

    <h1 class="lm-hero__title lm-hero__text-light">
      {{ section.settings.headline | default: 'Beauty, <em style="color:var(--color-pink); font-style:italic; font-weight:400;">neu</em> entdeckt.' }}
    </h1>

    <div class="lm-hero__bottom-row">
      <p class="lm-hero__subtext lm-hero__text-light">
        {{ section.settings.subtext | default: 'Dein Beauty-Onlineshop. Parfum, Pflege, Make-up und Haarkosmetik der größten Marken — kuratiert, schnell versendet und zu fairen Preisen.' }}
      </p>
      
      <div class="lm-hero__actions">
        <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="lm-hero__btn-primary">
          {{ section.settings.button_label | default: 'JETZT SHOPPEN' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

  </div>

  {%- if section.settings.marquee_text != blank -%}
  <div class="lm-hero__marquee-wrapper">
    <div class="lm-hero__marquee-track">
      {%- assign marquee_items = section.settings.marquee_text | split: ',' -%}
      {%- for i in (1..2) -%}
        <div class="lm-hero__marquee-group">
          {%- for text in marquee_items -%}
            <span class="lm-hero__marquee-item">
              <span>{{ text | strip }}</span>
              <span class="lm-hero__marquee-dot"></span>
            </span>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

</section>

{% stylesheet %}
  .lm-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: var(--color-text);
    margin-top: calc(-1 * var(--lm-header-h, 80px));
  }

  /* ── Background ── */
  .lm-hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .lm-hero__background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, calc(var(--overlay) / 100));
    z-index: 1;
    transition: background 0.8s ease;
  }
  [data-theme="light"] .lm-hero__background::after {
    background: rgba(255, 255, 255, calc(var(--overlay) / 100));
  }

  .lm-hero__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
    z-index: 0;
    transition: opacity 0.8s ease-in-out;
  }
  .lm-hero__bg--light {
    opacity: 0;
  }
  .lm-hero__bg--dark {
    opacity: 1;
  }
  [data-theme="light"] .lm-hero__bg--dark {
    opacity: 0;
  }
  [data-theme="light"] .lm-hero__bg--light {
    opacity: 1;
  }

  /* ── Content Inner ── */
  .lm-hero__content-inner {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 10rem 1.5rem 5rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100svh;
    position: relative;
    z-index: 2;
  }

  .lm-hero__top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    width: 100%;
  }

  .lm-hero__eyebrow {
    font-family: var(--font-sub, sans-serif);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-70);
  }

  .lm-hero__eyebrow-right {
    font-family: var(--font-sub, sans-serif);
    font-size: 11px;
    text-align: right;
    line-height: 1.8;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-40);
  }

  @media (max-width: 768px) {
    .hidden-mobile {
      display: none;
    }
    .lm-hero__bottom-row {
      flex-direction: column;
      align-items: flex-start !important;
    }
  }

  .lm-hero__title {
    font-family: var(--font-display, serif);
    font-size: clamp(64px, 11vw, 168px);
    line-height: 0.86;
    margin: 0;
    color: var(--color-text);
  }

  .lm-hero__bottom-row {
    margin-top: 2.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
  }

  .lm-hero__subtext {
    max-width: 28rem;
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    color: var(--color-text-70);
  }

  .lm-hero__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .lm-hero__btn-primary {
    background: var(--color-pink, #f496b0);
    color: #000;
    padding: 1rem 1.75rem;
    border-radius: 9999px;
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.3s ease;
  }
  .lm-hero__btn-primary:hover {
    opacity: 0.9;
  }

  /* Removed redundant hardcoded theme overrides — now handled by global tokens */

  /* ── Marquee ── */
  .lm-hero__marquee-wrapper {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 0;
    overflow: hidden;
    z-index: 5;
  }
  [data-theme="light"] .lm-hero__marquee-wrapper {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .lm-hero__marquee-track {
    display: flex;
    white-space: nowrap;
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    animation: lm-hero-marquee 40s linear infinite;
    color: #FAF9F6;
    font-weight: 700;
  }
  [data-theme="light"] .lm-hero__marquee-track {
    color: #2C2A29;
  }

  .lm-hero__marquee-group {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding-right: 2.5rem;
  }
  .lm-hero__marquee-item {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .lm-hero__marquee-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-pink, #f496b0);
  }
  @keyframes lm-hero-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_dark",
      "label": "Dark Mode Background"
    },
    {
      "type": "image_picker",
      "id": "image_light",
      "label": "Light Mode Background"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 0,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_left",
      "label": "Eyebrow Left",
      "default": "EXKLUSIVE BEAUTY-WELT"
    },
    {
      "type": "html",
      "id": "eyebrow_right",
      "label": "Eyebrow Right (HTML)",
      "default": "PREMIUM MARKEN<br>100% ORIGINAL<br>SCHNELLER VERSAND"
    },
    {
      "type": "html",
      "id": "headline",
      "label": "Headline (HTML)",
      "default": "Beauty, <em style=\"color:var(--color-pink); font-style:italic; font-weight:400;\">neu</em> entdeckt."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Dein Beauty-Onlineshop. Parfum, Pflege, Make-up und Haarkosmetik der größten Marken — kuratiert, schnell versendet und zu fairen Preisen."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "JETZT SHOPPEN"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee Text (comma-separated)",
      "default": "3–6 WERKTAGE, 30 TAGE RÜCKGABE, DEUTSCHLANDS SCHÖNSTES BEAUTY-SORTIMENT, GUTSCHEIN SICHERN, TOP MARKEN"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
