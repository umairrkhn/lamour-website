{%- assign overlay_pct = section.settings.overlay_opacity | default: 55 -%}

<section class="lm-hero mesh-hero grain full-width" aria-label="Hero">

  <div class="lm-hero__slides" aria-hidden="true" style="--overlay: {{ overlay_pct }}%">

    <div class="lm-hero__slide lm-hero__slide--1">
      {%- if section.settings.image != blank -%}
        {%- render 'image', image: section.settings.image, sizes: '100vw', class: 'lm-hero__bg' -%}
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0823/5728/9303/files/hero_H1_primary.png?v=1778330600"
             alt="" class="lm-hero__bg" loading="eager" fetchpriority="high" width="2000" height="1125">
      {%- endif -%}
    </div>

    <div class="lm-hero__slide lm-hero__slide--2">
      {%- if section.settings.image_2 != blank -%}
        {%- render 'image', image: section.settings.image_2, sizes: '100vw', class: 'lm-hero__bg' -%}
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0823/5728/9303/files/hero_H2_atmosphere.png?v=1778331595"
             alt="" class="lm-hero__bg" loading="lazy" width="2000" height="1125">
      {%- endif -%}
    </div>

    <div class="lm-hero__slide lm-hero__slide--3">
      {%- if section.settings.image_3 != blank -%}
        {%- render 'image', image: section.settings.image_3, sizes: '100vw', class: 'lm-hero__bg' -%}
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0823/5728/9303/files/hero_H3_lifestyle.png?v=1778330624"
             alt="" class="lm-hero__bg" loading="lazy" width="2000" height="1125">
      {%- endif -%}
    </div>

  </div>

  <div class="lm-hero__content lm-container" style="text-align: {{ section.settings.text_alignment | default: 'center' }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'eyebrow' -%}
          <p class="lm-hero__eyebrow font-sub reveal reveal-delay-1" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </p>

        {%- when 'heading' -%}
          <h1 class="lm-hero__title font-display hero-title" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </h1>

        {%- when 'rich_text' -%}
          <div class="lm-hero__body hero-sub reveal reveal-delay-2" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {%- when 'button' -%}
          <div class="lm-hero__cta reveal reveal-delay-3" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.button_url | default: '/collections/all' }}" class="lm-btn">
              {{ block.settings.button_label | default: 'JETZT SHOPPEN' }}
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

</section>

{% stylesheet %}
  .lm-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
    margin-top: calc(-1 * var(--lm-header-h, 80px));
  }

  /* ── Slideshow ── */
  .lm-hero__slides {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .lm-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: lm-hero-fade 18s ease-in-out infinite;
  }
  /* Dark overlay applied per-slide so it fades with the image */
  .lm-hero__slide::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, calc(var(--overlay) / 100));
  }
  .lm-hero__slide .image,
  .lm-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Stagger: slide 1 visible at t=0, crossfades at t=4-5s → 10-11s → 16-17s */
  .lm-hero__slide--1 { animation-delay: -1s; }
  .lm-hero__slide--2 { animation-delay: -14s; }
  .lm-hero__slide--3 { animation-delay: -8s; }

  @keyframes lm-hero-fade {
    0%       { opacity: 0; }
    5.55%    { opacity: 1; }  /* ~1s fade in */
    27.77%   { opacity: 1; }  /* hold ~4s */
    33.33%   { opacity: 0; }  /* ~1s fade out */
    100%     { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lm-hero__slide { animation: none; }
    .lm-hero__slide--1 { opacity: 1; }
  }

  /* ── Content ── */
  .lm-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-top: 80px;
    padding-bottom: 4rem;
  }
  [style*="text-align: left"] .lm-hero__content {
    align-items: flex-start;
  }

  .lm-hero__eyebrow {
    font-size: var(--text-micro);
    color: var(--color-pink);
    margin: 0;
  }

  .lm-hero__title {
    font-size: var(--text-hero);
    line-height: 1;
    color: #fff;
    margin: 0;
    max-width: 14ch;
  }

  .lm-hero__body {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: rgba(255, 255, 255, 0.70);
    max-width: 52ch;
    line-height: 1.7;
  }

  .lm-hero__cta {
    margin-top: 0.5rem;
  }

  [data-theme="light"] .lm-hero { color: #fff; }
  [data-theme="light"] .lm-hero__eyebrow { color: var(--color-pink); }
  [data-theme="light"] .lm-hero__title { color: #fff; }
  [data-theme="light"] .lm-hero__body { color: rgba(255, 255, 255, 0.70); }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Background image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Background image 3"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow label",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "PREMIUM PARFUMS & BEAUTY"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Entdecke Luxus"
        }
      ]
    },
    {
      "type": "rich_text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Erlebe die Welt der Düfte und Beauty mit ausgewählten Produkten der bekanntesten Marken.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "JETZT SHOPPEN"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "eyebrow", "settings": { "text": "PREMIUM PARFUMS & BEAUTY" } },
        { "type": "heading", "settings": { "heading": "Entdecke Luxus" } },
        { "type": "rich_text", "settings": { "text": "<p>Erlebe die Welt der Düfte und Beauty mit ausgewählten Produkten der bekanntesten Marken.</p>" } },
        { "type": "button", "settings": { "button_label": "JETZT SHOPPEN" } }
      ]
    }
  ]
}
{% endschema %}
