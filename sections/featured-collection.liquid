{%- liquid
  assign col = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
  assign columns = section.settings.columns_desktop | default: 4
-%}

<section class="lm-featured-collection">
  <div class="lm-container">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <header class="lm-featured-collection__header reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lm-featured-collection__eyebrow font-sub">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="lm-featured-collection__heading font-display">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if col != blank and col.products_count > 0 -%}
      <ul class="lm-featured-collection__grid" style="--cols: {{ columns }}" role="list">
        {%- for product in col.products limit: products_to_show -%}
          <li class="reveal" style="transition-delay: {{ forloop.index0 | modulo: columns | times: 80 }}ms">
            {%- render 'product-card', product: product -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- if col.products_count > products_to_show -%}
        <div class="lm-featured-collection__footer reveal">
          <a href="{{ col.url }}" class="lm-btn">
            Alle ansehen ({{ col.products_count }})
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="lm-featured-collection__empty">
        <p>Keine Produkte in dieser Kollektion.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .lm-featured-collection {
    padding: var(--space-section) 0;
    background: var(--color-bg);
  }

  .lm-featured-collection__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
  }

  .lm-featured-collection__eyebrow {
    font-size: var(--text-micro);
    color: var(--color-pink);
    margin: 0;
  }

  .lm-featured-collection__heading {
    font-size: var(--text-heading);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
  }

  .lm-featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 1024px) {
    .lm-featured-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .lm-featured-collection__grid {
      grid-template-columns: 1fr;
    }
  }

  .lm-featured-collection__footer {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .lm-featured-collection__empty {
    text-align: center;
    color: var(--color-text-40);
    padding: 4rem 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kollektion"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
