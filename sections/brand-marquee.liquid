{%- assign speed = section.settings.speed | default: 50 -%}

<section
  class="lm-marquee{% if section.settings.background_color == 'soft' %} lm-marquee--soft{% endif %}"
  aria-label="Unsere Top-Marken"
>
  <div class="hair full-width"></div>

  <div class="lm-marquee__track-wrap full-width" aria-hidden="true">
    <div class="lm-marquee__track" style="animation-duration: {{ speed }}s">
      <div class="lm-marquee__inner">
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/c/chanel-logo.svg" alt="Chanel" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/d/dior-2.svg" alt="Dior" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/g/gucci-logo-1.svg" alt="Gucci" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/burberry-wordmark.svg" alt="Burberry" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/c/calvin-klein-logo.svg" alt="Calvin Klein" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/h/hugo-boss.svg" alt="Hugo Boss" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/l/lancome-logo.svg" alt="Lancôme" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/l/loreal-logo.svg" alt="L'Oréal" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/balenciaga-logo.svg" alt="Balenciaga" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/g/givenchy-1.svg" alt="Givenchy" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/balmain-paris-logo.svg" alt="Balmain" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/v/valentino-logo.svg" alt="Valentino" class="lm-marquee__logo" loading="lazy"></div>
      </div>
      <div class="lm-marquee__inner" aria-hidden="true">
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/c/chanel-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/d/dior-2.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/g/gucci-logo-1.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/burberry-wordmark.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/c/calvin-klein-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/h/hugo-boss.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/l/lancome-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/l/loreal-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/balenciaga-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/g/givenchy-1.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/b/balmain-paris-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
        <div class="lm-marquee__logo-wrap"><img src="https://cdn.jsdelivr.net/gh/detain/svg-logos@master/svg/v/valentino-logo.svg" alt="" class="lm-marquee__logo" loading="lazy"></div>
      </div>
    </div>
  </div>

  <div class="hair full-width"></div>
</section>

{% stylesheet %}
  .lm-marquee {
    background: transparent;
    padding: 1.5rem 0;
    overflow: hidden;
  }
  .lm-marquee--soft {
    background: var(--color-bg-soft);
  }

  .lm-marquee__track-wrap {
    overflow: hidden;
    padding: 1.5rem 0;
  }
  .lm-marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll linear infinite;
  }
  .lm-marquee__inner {
    display: inline-flex;
    align-items: center;
    gap: 64px;
    padding-right: 64px;
  }

  .lm-marquee__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 130px;
    height: 36px;
    flex-shrink: 0;
  }
  .lm-marquee__logo {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    filter: brightness(0) opacity(0.5);
    transition: filter 0.3s ease, opacity 0.3s ease;
  }
  [data-theme="dark"] .lm-marquee__logo {
    filter: brightness(0) invert(1) opacity(0.65);
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand Marquee",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "soft",        "label": "Soft" }
      ],
      "default": "transparent"
    }
  ],
  "presets": [
    { "name": "Brand Marquee" }
  ]
}
{% endschema %}
