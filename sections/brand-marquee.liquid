{%- assign speed = section.settings.speed | default: 50 -%}

<section
  class="lm-marquee{% if section.settings.background_color == 'soft' %} lm-marquee--soft{% endif %}"
  aria-label="Unsere Top-Marken"
>
  <div class="hair full-width"></div>

  
  <div class="lm-marquee__track-wrap full-width" aria-hidden="true">
    <div class="lm-marquee__track" style="animation-duration: {{ speed }}s">
      {%- for i in (1..2) -%}
      <div class="lm-marquee__inner" {% if i == 2 %}aria-hidden="true"{% endif %}>
        {%- for block in section.blocks -%}
          <div class="lm-marquee__logo-wrap" {{ block.shopify_attributes }}>
            {%- assign handleized = block.settings.title | handleize -%}
            {%- capture svg_snippet -%}
              {%- render 'brand-logo', brand: handleized -%}
            {%- endcapture -%}
            
            {%- if svg_snippet != blank -%}
              {{ svg_snippet }}
            {%- elsif block.settings.svg_url != blank -%}
              <img src="{{ block.settings.svg_url }}" alt="{{ block.settings.title | escape }}" class="lm-marquee__logo" loading="lazy" width="140" height="36">
            {%- else -%}
              <span class="lm-marken__text-fallback" style="font-family: var(--font-heading-family); font-size: 1.5rem;">{{ block.settings.title }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="hair full-width"></div>
</section>

{% stylesheet %}
  .lm-marquee {
    background: transparent;
    padding: 1.5rem 0;
    overflow: hidden;
  }
  .lm-marquee--soft {
    background: var(--color-bg-soft);
  }

  .lm-marquee__track-wrap {
    overflow: hidden;
    padding: 1.5rem 0;
  }
  .lm-marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll linear infinite;
  }
  .lm-marquee__inner {
    display: inline-flex;
    align-items: center;
    gap: 64px;
    padding-right: 64px;
  }

  .lm-marquee__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 40px;
    flex-shrink: 0;
  }
  .lm-marquee__logo,
  .lm-marquee__logo-wrap svg,
  .lm-marquee__logo-wrap img {
    width: 100%;
    height: 100%;
    max-width: 140px;
    max-height: 36px;
    object-fit: contain;
    display: block;
    filter: brightness(0) opacity(0.5);
    transition: filter 0.3s ease, opacity 0.3s ease;
  }
  .lm-marquee__logo-wrap:hover .lm-marquee__logo,
  .lm-marquee__logo-wrap:hover svg,
  .lm-marquee__logo-wrap:hover img {
    filter: brightness(0) opacity(0.8);
  }
  [data-theme="light"] .lm-marquee__logo,
  [data-theme="light"] .lm-marquee__logo-wrap svg,
  [data-theme="light"] .lm-marquee__logo-wrap img {
    filter: brightness(0) opacity(0.5);
  }
  [data-theme="light"] .lm-marquee__logo-wrap:hover .lm-marquee__logo,
  [data-theme="light"] .lm-marquee__logo-wrap:hover svg,
  [data-theme="light"] .lm-marquee__logo-wrap:hover img {
    filter: brightness(0) opacity(0.8);
  }
  [data-theme="dark"] .lm-marquee__logo,
  [data-theme="dark"] .lm-marquee__logo-wrap svg,
  [data-theme="dark"] .lm-marquee__logo-wrap img {
    filter: brightness(0) invert(1) opacity(0.65);
  }
  [data-theme="dark"] .lm-marquee__logo-wrap:hover .lm-marquee__logo,
  [data-theme="dark"] .lm-marquee__logo-wrap:hover svg,
  [data-theme="dark"] .lm-marquee__logo-wrap:hover img {
    filter: brightness(0) invert(1) opacity(1);
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand Marquee",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "soft",        "label": "Soft" }
      ],
      "default": "transparent"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Brand Link"
        },
        {
          "type": "url",
          "id": "svg_url",
          "label": "SVG URL (Fallback)"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Brand Marquee" }
  ]
}
{% endschema %}
