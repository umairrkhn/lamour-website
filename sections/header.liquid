{%- if section.settings.show_announcement -%}
<div class="lm-announce" role="status">
  <span>{{ section.settings.announcement_text | escape }}</span>
</div>
{%- endif -%}

<header class="lm-header full-width" id="lm-header" role="banner">
  <lamour-header></lamour-header>

  <div class="lm-header__wrap">
    <div class="lm-container">
      <div class="lm-header__pill">

        <div class="lm-header__left">
          <a href="{{ routes.root_url }}" class="lm-header__logo" aria-label="{{ shop.name | escape }}">
            {%- if section.settings.logo != blank -%}
              {%- render 'image',
                image: section.settings.logo,
                width: section.settings.logo_width,
                class: 'lm-header__logo-img'
              -%}
            {%- else -%}
              <span class="lm-header__wordmark font-display"><span class="lm-wordmark-accent">L&rsquo;A</span>MOUR</span>
            {%- endif -%}
          </a>

          <nav class="lm-header__nav" aria-label="Hauptnavigation">
            <ul class="lm-header__cats" role="list">
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-parfum">PARFUM {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-gesicht">GESICHT {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-haare">HAARE {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-koerper">K&Ouml;RPER {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-makeup">MAKE-UP {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-gesundheit">GESUNDHEIT {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-baby">BABY &amp; KINDER {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
              <li class="lm-mega-item">
                <button class="lm-nav-btn" type="button" aria-expanded="false" aria-controls="lm-mega-tools">TOOLS {%- render 'icon', name: 'chevron-down' -%}</button>
              </li>
            </ul>
          </nav>
        </div>

        <div class="lm-header__right">
          <a href="{{ routes.search_url }}" class="lm-header__icon-btn" aria-label="Suche">{%- render 'icon', name: 'search' -%}</a>
          {%- if shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}" class="lm-header__icon-btn" aria-label="Konto">{%- render 'icon', name: 'user' -%}</a>
          {%- endif -%}
          {%- render 'theme-toggle' -%}
          <a href="{{ routes.cart_url }}" class="lm-header__icon-btn lm-header__cart" aria-label="Warenkorb ({{ cart.item_count }} Artikel)">
            {%- render 'icon', name: 'bag' -%}
            {%- if cart.item_count > 0 -%}
              <span class="lm-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
          </a>
          <lamour-mobile-menu class="lm-header__mob-toggle">
            <button class="lm-header__icon-btn" type="button" data-menu-toggle aria-label="Men&uuml; &ouml;ffnen" aria-expanded="false" aria-controls="lm-nav-overlay">
              {%- render 'icon', name: 'menu' -%}
            </button>
          </lamour-mobile-menu>
        </div>

      </div>
    </div>
  </div>

