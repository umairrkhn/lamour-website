      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Kostenloser Versand ab 0 € · Versandzeit 3–6 Werktage · Rückgabe innerhalb 30 Tagen"
    }
  ]
}
{% endschema %}
