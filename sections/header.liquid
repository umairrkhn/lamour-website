{% stylesheet %}
  .lm-announce {
    background: var(--color-pink);
    color: #000;
    text-align: center;
    padding: 7px 20px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lm-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: auto;
  }

  .lm-header__wrap {
    padding: 10px 0;
  }

  .lm-header__pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 9999px;
    padding: 10px 20px;
    background: rgba(12,12,12,0.55);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.08);
    transition: background 0.5s ease, border-color 0.5s ease, backdrop-filter 0.5s ease;
  }
  .lm-header.scrolled .lm-header__pill {
    background: rgba(20,20,20,0.82);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border-color: rgba(255,255,255,0.10);
  }
  [data-theme="light"] .lm-header__pill {
    background: rgba(250,249,247,0.72);
    border-color: rgba(0,0,0,0.08);
  }
  [data-theme="light"] .lm-header.scrolled .lm-header__pill {
    background: rgba(250,249,247,0.94);
    border-color: rgba(0,0,0,0.10);
  }

  .lm-header__left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    min-width: 0;
  }

  .lm-header__logo {
    flex-shrink: 0;
    text-decoration: none;
  }
  .lm-header__wordmark {
    font-size: 1.25rem;
    letter-spacing: -0.025em;
    color: var(--color-text);
  }
  .lm-wordmark-accent {
    color: var(--color-pink);
  }
  .lm-header__logo-img {
    max-height: 36px;
    width: auto;
  }

  .lm-header__nav {
    display: flex;
  }
  .lm-header__cats {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .lm-nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 7px 10px;
    border-radius: 9999px;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.72);
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }
  .lm-nav-btn:hover,
  .lm-mega-item.is-open .lm-nav-btn {
    background: rgba(255,255,255,0.06);
    color: #fff;
  }
  .lm-nav-btn svg {
    width: 11px;
    height: 11px;
    color: var(--color-pink);
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }
  .lm-mega-item.is-open .lm-nav-btn svg {
    transform: rotate(180deg);
  }
  [data-theme="light"] .lm-nav-btn {
    color: rgba(0,0,0,0.6);
  }
  [data-theme="light"] .lm-nav-btn:hover,
  [data-theme="light"] .lm-mega-item.is-open .lm-nav-btn {
    background: rgba(0,0,0,0.06);
    color: rgba(0,0,0,0.9);
  }

  .lm-header__right {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .lm-header__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    position: relative;
    flex-shrink: 0;
  }
  .lm-header__icon-btn:hover {
    background: rgba(255,255,255,0.06);
    color: #fff;
  }
  .lm-header__icon-btn svg {
    width: 18px;
    height: 18px;
  }
  [data-theme="light"] .lm-header__icon-btn {
    color: rgba(0,0,0,0.6);
  }
  [data-theme="light"] .lm-header__icon-btn:hover {
    background: rgba(0,0,0,0.06);
    color: rgba(0,0,0,0.9);
  }

  .lm-header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 15px;
    height: 15px;
    border-radius: 9999px;
    background: var(--color-pink);
    color: #000;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }

  .lm-header__mob-toggle {
    display: none;
  }

  .lm-mega-panels {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    padding-top: 8px;
    pointer-events: none;
  }
  .lm-mega-panel {
    pointer-events: auto;
  }
  .lm-mega-panel[hidden] {
    display: none;
  }

  .lm-mega-glass {
    background: rgba(18,18,18,0.92);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 20px;
    padding: 28px 32px;
    box-shadow: 0 24px 64px -12px rgba(0,0,0,0.7);
    animation: megaIn 0.25s cubic-bezier(0.2,0.7,0.2,1) both;
  }
  [data-theme="light"] .lm-mega-glass {
    background: rgba(255,255,255,0.97);
    border-color: rgba(0,0,0,0.08);
    box-shadow: 0 16px 48px -8px rgba(0,0,0,0.15);
  }

  @keyframes megaIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .lm-mega-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }


  .lm-mega-col {
    min-width: 0;
  }

  .lm-mega-head {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-pink);
    border-bottom: 1px solid rgba(255,255,255,0.10);
    padding-bottom: 8px;
    margin-bottom: 12px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lm-mega-head:hover {
    opacity: 0.75;
  }
  [data-theme="light"] .lm-mega-head {
    border-bottom-color: rgba(0,0,0,0.10);
  }

  .lm-mega-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lm-mega-list a {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.18s ease;
    line-height: 1.3;
  }
  .lm-mega-list a:hover {
    color: #fff;
  }
  [data-theme="light"] .lm-mega-list a {
    color: rgba(0,0,0,0.58);
  }
  [data-theme="light"] .lm-mega-list a:hover {
    color: rgba(0,0,0,0.9);
  }

  .lm-mega-foot {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  [data-theme="light"] .lm-mega-foot {
    border-top-color: rgba(0,0,0,0.08);
  }

  .lm-mega-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }
  [data-theme="light"] .lm-mega-label {
    color: rgba(0,0,0,0.35);
  }

  .lm-mega-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }
  .lm-mega-all svg {
    width: 14px;
    height: 14px;
  }
  .lm-mega-all:hover {
    color: #fff;
  }
  [data-theme="light"] .lm-mega-all {
    color: rgba(0,0,0,0.6);
  }
  [data-theme="light"] .lm-mega-all:hover {
    color: rgba(0,0,0,0.9);
  }

  .lm-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--color-bg);
    transform: translateX(100%);
    transition: transform var(--dur-slow, 0.45s) var(--ease-out, cubic-bezier(0.2,0.7,0.2,1));
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .lm-nav-overlay.open {
    transform: translateX(0);
  }
  .lm-nav-overlay__inner {
    display: flex;
    flex-direction: column;
    padding: 1.5rem clamp(1rem, 6vw, 3rem) 3rem;
    min-height: 100%;
    gap: 2rem;
  }
  .lm-nav-overlay__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .lm-nav-overlay__logo {
    font-size: 1.75rem;
    color: var(--color-pink);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .lm-mob-nav {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .lm-mob-item {
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.08));
  }
  .lm-mob-cat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: clamp(0.9rem, 3.5vw, 1.1rem);
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-text);
    text-align: left;
    transition: color 0.2s ease;
  }
  .lm-mob-cat:hover {
    color: var(--color-pink);
  }
  .lm-mob-chevron {
    flex-shrink: 0;
    color: var(--color-pink);
    transition: transform 0.25s ease;
    display: inline-flex;
  }
  .lm-mob-chevron svg {
    width: 16px;
    height: 16px;
  }
  .lm-mob-cat[aria-expanded="true"] .lm-mob-chevron {
    transform: rotate(180deg);
  }
  .lm-mob-panel[hidden] {
    display: none;
  }
  .lm-mob-panel {
    padding-bottom: 12px;
  }
  .lm-mob-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .lm-mob-links a {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-70, rgba(255,255,255,0.7));
    text-decoration: none;
    padding: 6px 0;
    transition: color 0.18s ease;
  }
  .lm-mob-links a:hover {
    color: var(--color-pink);
  }

  body > main {
    padding-top: var(--lm-header-h, 80px);
  }

  @media (max-width: 1060px) {
    .lm-header__nav {
      display: none;
    }
    .lm-header__mob-toggle {
      display: inline-flex;
    }
  }

  @media (max-width: 480px) {
    .lm-header__wrap {
      padding: 8px 0;
    }
    .lm-header__pill {
      padding: 8px 14px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function init() {
      var header = document.getElementById('lm-header');
      if (!header) return;

      var items = header.querySelectorAll('.lm-mega-item');

      function closeAll() {
        items.forEach(function (item) {
          item.classList.remove('is-open');
          var btn = item.querySelector('.lm-nav-btn');
          if (btn) btn.setAttribute('aria-expanded', 'false');
        });
        var panels = header.querySelectorAll('.lm-mega-panel');
        panels.forEach(function (p) { p.setAttribute('hidden', ''); });
      }

      items.forEach(function (item) {
        var btn = item.querySelector('.lm-nav-btn');
        if (!btn) return;
        var panelId = btn.getAttribute('aria-controls');
        btn.addEventListener('mouseenter', function () {
          closeAll();
          item.classList.add('is-open');
          btn.setAttribute('aria-expanded', 'true');
          if (panelId) {
            var p = document.getElementById(panelId);
            if (p) p.removeAttribute('hidden');
          }
        });
      });

      header.addEventListener('mouseleave', closeAll);

      document.addEventListener('click', function (e) {
        if (!e.target.closest('#lm-header')) closeAll();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAll();
      });

      function updateHeaderHeight() {
        document.documentElement.style.setProperty('--lm-header-h', header.offsetHeight + 'px');
      }
      updateHeaderHeight();
      window.addEventListener('resize', updateHeaderHeight);

      var mobCats = document.querySelectorAll('.lm-mob-cat');
      mobCats.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          mobCats.forEach(function (b) {
            b.setAttribute('aria-expanded', 'false');
            var p = document.getElementById(b.getAttribute('aria-controls'));
            if (p) p.setAttribute('hidden', '');
          });
          if (!expanded) {
            btn.setAttribute('aria-expanded', 'true');
            var panel = document.getElementById(btn.getAttribute('aria-controls'));
            if (panel) panel.removeAttribute('hidden');
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
{% endjavascript %}

