{% style %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}

  :root {
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;
    --style-border-radius-inputs: 2px;
    {%- if settings.container_width -%}
      --container: {{ settings.container_width }}px;
    {%- endif -%}
  }
{% endstyle %}
